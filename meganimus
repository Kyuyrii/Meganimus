    def run_sgdb_auto_transfer(self):
        settings = load_settings()
        api_key = settings["other"].get("sgdb_apikey", "").strip()
        if not api_key:
            QMessageBox.information(self, tr("APP_NAME"), tr("API_KEY_SAVE_FIRST"))
            return

        if not any(meganimus_config_dir.glob("essence-info-*.toml")):
            QMessageBox.information(self, tr("APP_NAME"), tr("NO_ESSENCES_FOUND"))
            return

        # Essences list. Also includes cases where paths are filled in but the files do not exist
        essences = []
        for toml_file in meganimus_config_dir.glob("essence-info-*.toml"):
            try:
                with open(toml_file, "r", encoding="utf-8") as fh:
                    essence = tomlkit.load(fh)
                essence_name = essence.get("name") or essence.get("display_name") or essence.get("id")
                gui_path = essence.get("gui_path", "")
                gui_missing = not gui_path or not Path(gui_path).exists()

                if essence_name and gui_missing:
                    essences.append((essence_name, toml_file))
            except Exception:
                continue

        if not essences:
            QMessageBox.information(self, tr("APP_NAME"), tr("AUTO_TRANSFER_NO_MISSING_ICONS"))
            return

        confirm = QMessageBox.question(
            self,
            tr("APP_NAME"),
            tr("AUTO_TRANSFER_ICONS_EXPLAIN"),
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
        if confirm != QMessageBox.StandardButton.Yes:
            return

        # Create progress dialog
        progress_dialog = QProgressDialog(tr("AUTO_TRANSFER_IN_PROGRESS"), tr("CANCEL_BUTTON"), 0, 100, self)
        progress_dialog.setWindowTitle(tr("APP_NAME"))
        progress_dialog.setWindowModality(Qt.WindowModality.WindowModal)
        progress_dialog.setAutoClose(True)
        progress_dialog.setAutoReset(True)
        progress_dialog.setMinimumWidth(400)
        progress_dialog.show()

        self._cancel_auto = False
        progress_dialog.canceled.connect(lambda: setattr(self, '_cancel_auto', True))

        # Progress setup
        total = len(essences)
        progress_dialog.setMaximum(total)
        progress_dialog.setValue(0)
        QApplication.processEvents()

        # Cache directory for icons
        icons_tmp_dir = Path(tempfile.gettempdir()) / "Meganimus" / "sgdb_icons"
        icons_tmp_dir.mkdir(parents=True, exist_ok=True)

        completed = 0
        downloads = []  # Stores the icon paths before copying

        for essence_name, toml_file in essences:
            if self._cancel_auto or progress_dialog.wasCanceled():
                break

            icon_cache_path = None

            try:
                # Search on SteamGridDB
                search_url = f"https://www.steamgriddb.com/api/v2/search/autocomplete/{essence_name}"
                headers = {"Authorization": f"Bearer {api_key}"}

                with requests.get(search_url, headers=headers, timeout=15) as resp:
                    resp.raise_for_status()
                    data = resp.json().get("data", [])

                if not data:
                    completed += 1
                    progress_dialog.setValue(completed)
                    QApplication.processEvents()
                    continue

                game = data[0]
                game_id = game.get("id")
                steam_game_name = game.get("name") or str(game_id)

                # Download icon using ArtworkLoader
                icon_loader = ArtworkLoader(api_key, game_id, "icons")

                # Create a local event loop to wait for the thread
                loop = QEventLoop()
                icon_results = []

                def on_icon_finished(results):
                    nonlocal icon_results
                    icon_results = results
                    loop.quit()

                def on_icon_error(error_msg):
                    print(error_msg)
                    loop.quit()

                icon_loader.finished.connect(on_icon_finished)
                icon_loader.error.connect(on_icon_error)
                icon_loader.start()

                # Process events while waiting
                timer = QTimer()
                timer.timeout.connect(lambda: QApplication.processEvents())
                timer.start(100)

                loop.exec()
                timer.stop()

                # Process icon results
                if icon_results and len(icon_results) > 0:
                    best_icon = icon_results[0]

                    if best_icon and best_icon.get("img_data"):
                        img_data = best_icon["img_data"]
                        img_url = best_icon["url"]

                        if img_url:
                            ext = Path(img_url).suffix
                            if not ext or len(ext) > 6:
                                ext = ".png"

                            # Save to cache first
                            icon_cache_filename = icons_tmp_dir / f"{steam_game_name}_icon_{best_icon['id']}{ext}"
                            with icon_cache_filename.open("wb") as fh:
                                fh.write(img_data)
                            icon_cache_path = icon_cache_filename

                # Store for later copying
                downloads.append((essence_name, toml_file, icon_cache_path))

            except Exception as e:
                print(tr("AUTO_TRANSFER_GENERAL_ERROR", essence_name=essence_name, error=str(e)))
            finally:
                completed += 1
                progress_dialog.setValue(completed)
                QApplication.processEvents()

        # After all downloads are complete, copy from cache to gui
        if not self._cancel_auto and not progress_dialog.wasCanceled():
            for essence_name, toml_file, icon_cache_path in downloads:
                normalized = essence_name.lower().replace(" ", "_").replace("/", "_").replace("\\", "_")
                copied_icon = False

                try:
                    with open(toml_file, "r", encoding="utf-8") as fh:
                        essence_toml = tomlkit.load(fh)
                except Exception:
                    essence_toml = {}

                if icon_cache_path and icon_cache_path.exists():
                    try:
                        dest_icon = meganimus_gui_dir / f"{normalized}{icon_cache_path.suffix}"
                        shutil.copy2(icon_cache_path, dest_icon)
                        essence_toml["gui_path"] = str(dest_icon)
                        copied_icon = True

                        # Delete the file from the cache folder when finished
                        icon_cache_path.unlink()
                    except Exception:
                        copied_icon = False

                if copied_icon:
                    try:
                        with open(toml_file, "w", encoding="utf-8") as fh:
                            tomlkit.dump(essence_toml, fh)
                    except Exception:
                        pass

        # Clear downloads list to free memory
        downloads.clear()

        if not self._cancel_auto and not progress_dialog.wasCanceled():
            QMessageBox.information(self, tr("APP_NAME"), tr("AUTO_TRANSFER_FINISHED"))

        self.load_essences()
        progress_dialog.close()

