    def filter_essences(self, _=None):
        search_text = self.search_bar.text().lower()
        selected_executor = self.executor_filter.currentText()

        first_visible_item = None
        current_item = self.essence_list_widget.currentItem()

        for i in range(self.essence_list_widget.count()):
            item = self.essence_list_widget.item(i)
            name_match = search_text in item.text().lower()

            executor_name = item.data(Qt.ItemDataRole.UserRole + 1)
            executor_match = (selected_executor == tr("ALL_ESSENCES")) or (executor_name == selected_executor)

            visible = name_match and executor_match
            item.setHidden(not visible)

            if visible and first_visible_item is None:
                first_visible_item = item

        if current_item is None or current_item.isHidden():
            if first_visible_item:
                self.essence_list_widget.setCurrentItem(first_visible_item)

    def load_essences(self):
        """Loads essence data from TOML files and populates the list, preserving the selection by TOML file."""

        # Save scroll position
        scroll_pos = self.essence_list_widget.verticalScrollBar().value()

        # Save which file was selected
        selected_essence_file = None
        current_item = self.essence_list_widget.currentItem()
        if current_item:
            selected_essence_file = current_item.data(Qt.ItemDataRole.UserRole)

        self.essence_list_widget.clear()

        if not meganimus_config_dir.exists():
            return

        essence_files = sorted(meganimus_config_dir.glob("essence-info-*.toml"))
        essences = []

        restored_selection_item = None
        for essence_file in essence_files:
            try:
                with open(essence_file, encoding="utf-8") as f:
                    essence_data = tomlkit.load(f)

                essences.append((essence_data, essence_file))

                item = self.add_essence_to_list(essence_data)
                item.setData(Qt.ItemDataRole.UserRole, essence_file)

                if selected_essence_file and selected_essence_file == essence_file:
                    restored_selection_item = item

            except (IOError, tomlkit.exceptions.ParseError) as e:
                print(tr("ERROR_LOADING_FILE", file=essence_file, error=e))

        # Restores the selection
        if restored_selection_item:
            self.essence_list_widget.setCurrentItem(restored_selection_item)
        else:
            if self.essence_list_widget.count() > 0:
                self.essence_list_widget.setCurrentRow(0)

        # Reapply the search filter
        if hasattr(self, "search_bar"):
            current_text = self.search_bar.text()
            self.filter_essences(current_text)

        # Restore scroll position and filter of the executor
        self.essence_list_widget.verticalScrollBar().setValue(scroll_pos)

        selected_executor_text = self.executor_filter.currentText()

        executors = ["Azahar", "Cemu", "Dolphin", "DuckStation", "Eden", "Flycast", "Linux", "MelonDS", "mGBA", "PCSX2", "PPSSPP", "RMG", "RPCS3", "Ryubing", "Snes9x", "UMU", "Wine", "xemu"]
        used_executors = set(essence_data.get("executor", "Linux") for essence_data, _ in essences)
        self.executor_filter.clear()
        self.executor_filter.addItem(tr("ALL_ESSENCES"))
        for executor in executors:
            if executor in used_executors:
                self.executor_filter.addItem(executor)

        index_to_restore = self.executor_filter.findText(selected_executor_text)
        if index_to_restore != -1:
            self.executor_filter.setCurrentIndex(index_to_restore)
        else:
            self.executor_filter.setCurrentIndex(0)

    def fix_essence_paths(self):
        # Fix paths in all essences if they don't match current meganimus_dir
        current_base = str(meganimus_home_dir)

        for toml_file in meganimus_config_dir.glob("essence-info-*.toml"):
            try:
                with open(toml_file, 'r+', encoding='utf-8') as f:
                    data = tomlkit.load(f)
                    modified = False

                    for field in ['game_path', 'wineprefix', 'gui_path']:
                        if field in data and '/App/Meganimus/' in data[field]:
                            old_base = data[field].split('/App/Meganimus/')[0]
                            if old_base != current_base:
                                data[field] = data[field].replace(old_base, current_base, 1)
                                modified = True

                    if modified:
                        f.seek(0)
                        tomlkit.dump(data, f)
                        f.truncate()
            except:
                continue

