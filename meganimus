            if cb.isVisible():
                cb.setChecked(False)

    def reset_fields(self):
        self.executor_combo.setCurrentIndex(0)
        self.game_input.setText(tr("DO_NOT_CHANGE"))
        self.wineprefix_input.setText(tr("DO_NOT_CHANGE"))
        self.gui_input.setText(tr("DO_NOT_CHANGE"))
        self.lang_combo.setCurrentIndex(0)
        self.env_input.setText(tr("DO_NOT_CHANGE"))
        self.args_input.setText(tr("DO_NOT_CHANGE"))

    # Apply changes
    def apply_multiple_edit(self):
        selected = [cb for cb in self.essence_checkboxes.values() if cb.isChecked()]
        if not selected:
            QMessageBox.warning(self, tr("APP_NAME"), tr("NO_ESSENCE_SELECTED_MULTIPLE"))
            return

        for cb in selected:
            with open(cb.essence_file, encoding="utf-8") as f:
                data = tomlkit.load(f)

            # Executor
            executor = self.executor_combo.currentText()
            if executor != tr("DO_NOT_CHANGE"):
                data["executor"] = executor

            # Game
            game_path = self.game_input.text()
            if game_path != tr("DO_NOT_CHANGE"):
                data["game_path"] = game_path

            # WinePrefix
            wineprefix = self.wineprefix_input.text()
            if wineprefix != tr("DO_NOT_CHANGE"):
                data["wineprefix"] = wineprefix

            # Gui
            gui_input_text = self.gui_input.text().strip()
            if gui_input_text != tr("DO_NOT_CHANGE"):
                if not gui_input_text:
                    if data.get("gui_path"):
                        old_gui_path = Path(data["gui_path"])
                        if old_gui_path.exists() and old_gui_path.is_file():
                            try:
                                old_gui_path.unlink()
                            except Exception:
                                pass
                    data["gui_path"] = ""
                else:
                    gui_path = Path(gui_input_text)
                    if gui_path.exists() and gui_path.is_file():
                        if data.get("gui_path"):
                            old_gui_path = Path(data["gui_path"])
                            if old_gui_path.exists() and old_gui_path.is_file():
                                try:
                                    old_gui_path.unlink()
                                except Exception:
                                    pass

                        ext = gui_path.suffix.lower()
                        new_gui_path = meganimus_gui_dir / f"{data['name'].replace(' ', '_').lower()}{ext}"
                        try:
                            shutil.copyfile(gui_path, new_gui_path)
                            data["gui_path"] = str(new_gui_path)
                        except Exception:
                            data["gui_path"] = ""

            # Language
            lang = self.lang_combo.currentText()
            if lang != tr("DO_NOT_CHANGE"):
                data["language"] = "" if lang == tr("INDEFINITE") else lang

            # Env vars
            env_vars = self.env_input.text()
            if env_vars != tr("DO_NOT_CHANGE"):
                data["env_vars"] = env_vars.strip()

            # Essence args
            args = self.args_input.text()
            if args != tr("DO_NOT_CHANGE"):
                data["essence_args"] = args.strip()

            # Save TOML
            with open(cb.essence_file, "w", encoding="utf-8") as f:
                tomlkit.dump(data, f)

        self.update_executor_filter()
        self.update_essence_list()

        self.parent().load_essences()

        if hasattr(self, "essence_info_viewer") and self.essence_info_viewer:
            self.essence_info_viewer.reload_current_selection()

        QMessageBox.information(
            self,
            tr("MULTIPLE_ESSENCE_EDITOR"),
            tr("CHANGES_SAVED"))

