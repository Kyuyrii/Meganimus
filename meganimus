        if hasattr(self.parent(), "essence_info_viewer"):
            self.parent().essence_info_viewer = None
        super().closeEvent(event)

    # Loads the available TOML files.
    def load_essences(self) -> list[dict]:
        essences = []
        if not meganimus_config_dir.exists():
            return essences

        for file in meganimus_config_dir.glob("essence-info-*.toml"):
            try:
                with open(file, "r", encoding="utf-8") as f:
                    inv = tomlkit.load(f)
                    inv["__filename"] = file.name
                    essences.append(inv)
            except Exception:
                pass
        return essences

    # Create radio buttons
    def create_essence_buttons(self):
        # Sort alphabetically by filename (essence-info-)
        def get_filename_sort_key(essence):
            filename = essence.get("__filename", "")
            return Path(filename).stem.lower()

        self.essences.sort(key=get_filename_sort_key)

        first_rb = None
        for inv in self.essences:
            filename = inv.get("__filename", "")
            display_name = inv.get("name") or inv.get("display_name") or inv.get("id")
            rb = QRadioButton(display_name)
            rb.setProperty("essence_filename", filename)
            self.button_group.addButton(rb)
            self.scroll_layout.addWidget(rb)
            self.radio_buttons.append(rb)
            if first_rb is None:
                first_rb = rb

        self.scroll_layout.addStretch(1)

        # Initial Selection
        if first_rb:
            first_rb.setChecked(True)
            self.show_essence_info_from_file(first_rb.property("essence_filename"))

    # Search filter
    def filter_essences(self, text: str):
        text = (text or "").strip().lower()
        first_visible = None
        search_mode = self.search_mode_combo.currentText()

        for rb in self.radio_buttons:
            filename = rb.property("essence_filename")
            match = False

            if search_mode == tr("NAME"):
                match = text in rb.text().lower()
            else:  # Content
                file_path = meganimus_config_dir / filename
                if file_path.exists():
                    try:
                        with open(file_path, "r", encoding="utf-8") as f:
                            data = tomlkit.load(f)
                        # Search for content only in these fields
                        for key in ["game_path", "wineprefix", "language", "env_vars", "essence_args"]:
                            value = str(data.get(key, "")).lower()
                            if text in value:
                                match = True
                                break
                    except Exception:
                        match = False

            rb.setVisible(match)
            if match and first_visible is None:
                first_visible = rb

        if first_visible:
            first_visible.setChecked(True)

            checked = self.button_group.checkedButton()
            if checked:
                filename = checked.property("essence_filename")
                self.show_essence_info_from_file(filename)
        else:
            self.text_box.clear()

    # When a radio button is clicked
    def handle_button_toggled(self, button, checked: bool):
        if not checked or not button:
            return
        filename = button.property("essence_filename")
        if filename:
            self.show_essence_info_from_file(filename)

    # Display information by reading the TOML.
    def show_essence_info_from_file(self, filename: str):
        file_path = meganimus_config_dir / filename
        if not file_path.exists():
            self.text_box.clear()
            return

        try:
            with open(file_path, "r", encoding="utf-8") as f:
                inv = tomlkit.load(f)
        except Exception:
            self.text_box.clear()
            return

        self.text_box.clear()
        cursor = self.text_box.textCursor()
        palette = QApplication.palette()
        key_color = palette.color(QPalette.ColorRole.Highlight)
        value_color = palette.color(QPalette.ColorRole.Text)

        translations = {
            "name": tr("ESSENCE_NAME"),
            "executor": tr("EXECUTOR"),
            "wineprefix": tr("WINEPREFIX"),
            "game_path": tr("GAME_PATH"),
            "gui_path": tr("ESSENCE_GUI_PATH"),
            "language": tr("ESSENCE_LANGUAGE"),
            "env_vars": tr("ENVIRONMENT_VARS"),
            "essence_args": tr("ESSENCE_ARGS"),
        }

        value_translations = {}

        for key, value in inv.items():
            if isinstance(value, bool):
                value = "✅" if value else "❌"

            if isinstance(value, str) and value in value_translations:
                value = value_translations[value]
                value = re.sub(r"\s*\(.*?\)", "", value).strip()

            key_label = translations.get(key, key)

            fmt_key = QTextCharFormat()
            fmt_key.setForeground(QColor(key_color))

            fmt_value = QTextCharFormat()
            fmt_value.setForeground(QColor(value_color))

            cursor.insertText(f"{key_label}: ", fmt_key)
            cursor.insertText(str(value) + "\n", fmt_value)

        self.text_box.moveCursor(QTextCursor.MoveOperation.Start)

    # Updates the right panel while maintaining the selection.
    def reload_current_selection(self):
        checked_button = self.button_group.checkedButton()
        if checked_button:
            filename = checked_button.property("essence_filename")
            self.show_essence_info_from_file(filename)

