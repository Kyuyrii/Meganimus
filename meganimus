# Loads translations from TOML files.
def load_translations():
    toml_translations = {}
    toml_languages = {}

    # Translation folders
    translation_dirs = [
        meganimus_dir / "translation",
        Path(sys.argv[0]).parent / "translation",
    ]

    if "XDG_DATA_DIRS" in os.environ:
        for path in os.environ["XDG_DATA_DIRS"].split(":"):
            translation_dirs.append(Path(path) / "Meganimus" / "translation")
    else:
        translation_dirs.append(Path("/usr/share/Meganimus/translation"))
        translation_dirs.append(Path("/usr/local/share/Meganimus/translation"))

    for translation_folder in translation_dirs:
        if translation_folder.exists():
            for toml_file in translation_folder.glob("meganimus-translation-*.toml"):
                try:
                    lang_code = toml_file.stem.replace("meganimus-translation-", "")
                    with open(toml_file, 'r', encoding='utf-8') as f:
                        lang_data = tomlkit.load(f)

                    # Add to translations
                    toml_translations[lang_code] = lang_data

                    # Adds to supported languages
                    lang_name = lang_data.get("language_name", lang_code)
                    toml_languages[lang_name] = lang_code

                    print(f"Loaded translation: {lang_name} ({lang_code})")

                except Exception as e:
                    print(f"Error loading translation {toml_file}: {e}")

    return toml_translations, toml_languages

# Load translations
available_translations, available_languages = load_translations()
if LANG not in available_translations:
    LANG = 'en_US'

def tr(key, **kwargs):
    # Get the translated string from external translations
    if LANG in available_translations:
        translation_dict = available_translations[LANG]
        translated_string = translation_dict.get(key)

        if translated_string:
            # Replace special variables
            translated_string = translated_string.replace("{__version__}", __version__)
            translated_string = translated_string.replace("{__creator__}", __creator__)

            # Apply formatting with any additional kwargs
            try:
                return translated_string.format(**kwargs)
            except KeyError:
                return translated_string

    # If no translation found, return the key itself
    return key

