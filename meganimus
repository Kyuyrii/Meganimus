    def _on_package_type_changed(self, executor_name, path_input, browse_btn, default_commands, index):
        package = self.executor_widgets[executor_name]["package_combo"].currentText()

        if package == tr("INDEFINITE"):
            path_input.setText("")
            path_input.setReadOnly(False)
            browse_btn.setEnabled(True)
        else:  # Snap or Flatpak
            cmd = default_commands.get(executor_name, {}).get(package, "")
            if cmd:
                path_input.setText(cmd)
            else:
                path_input.setText(tr("INDEFINITE"))
            path_input.setReadOnly(True)
            browse_btn.setEnabled(False)

