        main_layout.addWidget(self.remove_button)

        # Dictionary essence_name -> checkbox
        self.essence_checkboxes = {}
        self.load_essences()

    def keyPressEvent(self, event):
        if event.key() in (Qt.Key.Key_Return, Qt.Key.Key_Enter):
            # Prevents Enter from triggering something that is not selected
            return
        super().keyPressEvent(event)

    def load_essences(self):
        """It loads all the essences and creates the checkboxes."""
        self.essence_checkboxes.clear()
        while self.scroll_layout.count():
            item = self.scroll_layout.takeAt(0)
            widget = item.widget()
            if widget:
                widget.deleteLater()

        essence_files = sorted(meganimus_config_dir.glob("essence-info-*.toml"))

        # Executors used
        used_executors = set()

        for essence_file in essence_files:
            try:
                with open(essence_file, encoding="utf-8") as f:
                    data = tomlkit.load(f)
                name = data.get("name", essence_file.stem)
                cb = QCheckBox(name)
                cb.essence_file = essence_file
                executor = data.get("executor", "Linux")
                cb.executor = executor
                cb.gui_path = data.get("gui_path")
                self.scroll_layout.addWidget(cb)
                self.essence_checkboxes[name] = cb

                # Adds used executors to the list.
                used_executors.add(executor)

            except Exception:
                continue
        self.scroll_layout.addStretch()

        # Add the used executors to the combobox.
        self.executor_filter.clear()
        self.executor_filter.addItem(tr("ALL_ESSENCES"))

        # Add executors in alphabetical order.
        for executor in sorted(used_executors, key=str.lower):
            self.executor_filter.addItem(executor)

    def update_essence_list(self):
        """Filter the essences by the selected text and executor."""
        text = self.search_input.text().lower()
        selected_executor = self.executor_filter.currentText()

        for name, cb in self.essence_checkboxes.items():
            executor = getattr(cb, "executor", "Linux")
            matches_text = text in name.lower()
            matches_executor = (selected_executor == tr("ALL_ESSENCES")) or (executor == selected_executor)
            cb.setVisible(matches_text and matches_executor)

    def select_all_essences(self):
        for cb in self.essence_checkboxes.values():
            if cb.isVisible():
                cb.setChecked(True)

    def deselect_all_essences(self):
        for cb in self.essence_checkboxes.values():
            if cb.isVisible():
                cb.setChecked(False)

    def remove_selected_essences(self):
        to_remove = [cb for cb in self.essence_checkboxes.values() if cb.isChecked()]
        if not to_remove:
            QMessageBox.warning(self, tr("APP_NAME"), tr("NO_ESSENCE_SELECTED_MULTIPLE"))
            return

        msg = QMessageBox(self)
        msg.setIcon(QMessageBox.Icon.Warning)
        msg.setWindowTitle(tr("MULTIPLE_ESSENCE_REMOVER"))
        msg.setText(tr("DELETE_ESSENCES_CONFIRM_MESSAGE"))
        msg.setStandardButtons(QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)

        if msg.exec() != QMessageBox.StandardButton.Yes:
            return

        for cb in to_remove:
            # Remove TOML
            try:
                if cb.essence_file.exists():
                    cb.essence_file.unlink()
            except Exception:
                pass

            # Remove gui icon
            if cb.gui_path:
                gui_path = Path(cb.gui_path)
                if gui_path.exists() and gui_path.is_file():
                    try:
                        gui_path.unlink()
                    except Exception:
                        pass

        self.load_essences()
        self.parent().load_essences()

        self.accept()

