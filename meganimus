    def is_meganimus_desktop(self, file_path: Path) -> bool:
        if not file_path.exists() or file_path.suffix != ".desktop":
            return False

        return file_path.stem.startswith("meganimus-")

    # Checkbox Helpers
    def select_all_checkboxes(self):
        for cb in self.checkbox_widgets[self.current_view].values():
            if cb.isVisible():
                cb.setChecked(True)

    def deselect_all_checkboxes(self):
        for cb in self.checkbox_widgets[self.current_view].values():
            if cb.isVisible():
                cb.setChecked(False)

    # List view update
    def update_list_view(self):
        # Save current states
        for name, cb in self.checkbox_widgets[self.current_view].items():
            self.checkbox_states[self.current_view][name] = cb.isChecked()

        # Define current view
        self.current_view = "desktop" if self.view_combo.currentIndex() == 0 else "menu"

        # Get the appropriate folder path based on current view
        if self.current_view == "desktop":
            folder_path = Path(self.desktop_dir_input.text())
        else:
            # For menu view, use .local/share/applications
            dot_local = Path(self.dot_local_input.text())
            folder_path = dot_local / "share" / "applications"

        existing_desktops = set()

        if folder_path.exists():
            safe_to_display = {data["safe_essence_name"]: name
                            for name, data in self.essences.items()
                            if "safe_essence_name" in data}

            for f in folder_path.glob("meganimus-*.desktop"):
                if self.is_meganimus_desktop(f):
                    safe_name = f.stem.replace("meganimus-", "")
                    if safe_name in safe_to_display:
                        existing_desktops.add(safe_to_display[safe_name])

        # Clean up the old layout.
        while self.scroll_layout.count():
            item = self.scroll_layout.takeAt(0)
            if item.widget():
                item.widget().setParent(None)

        # Create/recreate checkboxes for this view.
        new_checkboxes = {}
        for essence in sorted(self.essences.keys()):
            cb = QCheckBox(essence)
            # Combine saved states with existing shortcuts
            was_checked = self.checkbox_states[self.current_view].get(essence, False)
            exists_in_folder = essence in existing_desktops
            cb.setChecked(self.checkbox_states[self.current_view].get(essence, essence in existing_desktops))
            new_checkboxes[essence] = cb
        self.checkbox_widgets[self.current_view] = new_checkboxes

        # Add only widgets filtered by the search.
        text = self.search_bar.text().lower()
        for name, cb in self.checkbox_widgets[self.current_view].items():
            if text in name.lower():
                self.scroll_layout.addWidget(cb)
                cb.show()
            else:
                cb.hide()

        self.scroll_layout.addStretch()

    # Loading and saving
    def load_essences(self) -> dict:
        essences = {}
        if not meganimus_config_dir.exists():
            return essences
        for f in meganimus_config_dir.glob("essence-info-*.toml"):
            try:
                content = f.read_text(encoding="utf-8")
                data = tomlkit.loads(content)
                name = data.get("name")
                gui_path = data.get("gui_path", "")
                game_path = data.get("game_path", "")
                safe_essence_name = f.stem.replace("essence-info-", "")
                if name:
                    essences[name] = {
                        "gui_path": gui_path,
                        "game_path": game_path,
                        "safe_essence_name": safe_essence_name}
            except Exception:
                continue
        return essences

    def load_shortcut_manager_info(self):
        # Load directories from TOML settings.
        settings = load_settings()
        shortcut_section = settings.get("shortcut", {})

        # Get values from config or empty strings
        desktop_dir = shortcut_section.get("desktop_dir", "")
        dot_local_dir = shortcut_section.get("dot_local_dir", "")

        # If desktop_dir is empty in config, calculate default
        if not desktop_dir:
            desktop_dir = self.get_default_desktop_dir()

        # If dot_local_dir is empty in config, use default
        if not dot_local_dir:
            dot_local_dir = str(meganimus_home_dir / ".local")

        # Processed settings for shortcut manager
        info = {
            "desktop_dir": str(desktop_dir),
            "dot_local_dir": str(dot_local_dir),
        }

        return info

    def get_default_desktop_dir(self):
        # Get default desktop directory from XDG user dirs.
        desktop_dir = meganimus_home_dir / "Desktop"
        user_dirs_file = meganimus_home_dir / ".config" / "user-dirs.dirs"
        if user_dirs_file.exists():
            try:
                with open(user_dirs_file, encoding="utf-8") as f:
                    for line in f:
                        line = line.strip()
                        if line.startswith("XDG_DESKTOP_DIR"):
                            path = line.split("=", 1)[1].strip().strip('"')
                            path = path.replace("$HOME", str(meganimus_home_dir))
                            desktop_dir = Path(path)
                            break
            except Exception:
                pass
        return str(desktop_dir)

    def save_shortcut_manager_info(self):
        # Save directories to TOML settings.
        settings = load_settings()
        settings.setdefault("shortcut", {})
        settings["shortcut"]["desktop_dir"] = self.shortcut_manager_info.get("desktop_dir", "")
        settings["shortcut"]["dot_local_dir"] = self.shortcut_manager_info.get("dot_local_dir", "")
        save_settings(settings)

    def browse_folder(self, line_edit: QLineEdit):
        folder = QFileDialog.getExistingDirectory(self,
        tr("SELECT_FOLDER"),
        str(meganimus_home_dir))
        if not folder:
            return

        new_folder = Path(folder)
        line_edit.setText(str(new_folder))

        self.update_list_view()

    def remove_all_meganimus_desktops(self, folder: Path):
        if not folder.exists():
            return

        for f in folder.glob("meganimus-*.desktop"):
            try:
                if self.is_meganimus_desktop(f):
                    f.unlink()
            except Exception as e:
                print(tr("ERROR_REMOVING_FILE", file=f, error=e))

    def update_and_apply(self):
        desktop_dir = Path(self.desktop_dir_input.text().strip())
        dot_local_dir = Path(self.dot_local_input.text().strip())

        # Define menu applications directory
        applications_dir = dot_local_dir / "share" / "applications"

        # Create desktop directory if it doesn't exist
        try:
            desktop_dir.mkdir(parents=True, exist_ok=True)
        except Exception:
            QMessageBox.warning(
                self,
                tr("APP_NAME"),
                tr("ERROR_CREATING_SHORTCUTS_LOCATION", path=desktop_dir))
            return

        # Check if .local directory exists
        if not dot_local_dir.exists():
            QMessageBox.warning(
                self,
                tr("APP_NAME"),
                tr("ERROR_CREATING_SHORTCUTS_LOCATION", path=dot_local_dir))
            return

        applications_dir.mkdir(parents=True, exist_ok=True)

        old_desktop_dir = Path(self.shortcut_manager_info.get("desktop_dir", ""))
        old_dot_local_dir = Path(self.shortcut_manager_info.get("dot_local_dir", ""))

        # Remove old desktop files from previous locations
        self.remove_all_meganimus_desktops(old_desktop_dir)

        # Remove old menu files from previous .local/share/applications
        old_applications_dir = old_dot_local_dir / "share" / "applications"
        self.remove_all_meganimus_desktops(old_applications_dir)

        # Update info with new paths
        self.shortcut_manager_info["desktop_dir"] = str(desktop_dir)
        self.shortcut_manager_info["dot_local_dir"] = str(dot_local_dir)

        self.save_shortcut_manager_info()

        # Remove existing .desktop files from new locations
        self.remove_all_meganimus_desktops(desktop_dir)
        self.remove_all_meganimus_desktops(applications_dir)

        # Create desktop shortcuts
        for name, cb in self.checkbox_widgets["desktop"].items():
            checked = cb.isChecked()
            self.create_desktop_file(name, checked, desktop_dir)

        # Create menu shortcuts
        for name, cb in self.checkbox_widgets["menu"].items():
            checked = cb.isChecked()
            self.create_desktop_file(name, checked, applications_dir)

        # Set executable permissions
        os.system(f'chmod +x "{desktop_dir}/"meganimus-*.desktop 2>/dev/null')
        os.system(f'chmod +x "{applications_dir}/"meganimus-*.desktop 2>/dev/null')

        self.update_list_view()
        self.accept()

    def create_desktop_file(self, name: str, checked: bool, folder: Path):
        if not checked:
            return

        essence_data = self.essences.get(name, {})
        safe_name = essence_data.get("safe_essence_name", "")
        game_path = essence_data.get("game_path", "")

        # Load essence info
        essence_file_path = meganimus_config_dir / f"essence-info-{safe_name}.toml"
        with essence_file_path.open('r', encoding='utf-8') as f:
            essence_info = tomlkit.load(f)

        executor = essence_info.get("executor", "Linux")
        essence_args = essence_info.get("essence_args", "").strip()
        env_vars = essence_info.get("env_vars", "").strip()
        wineprefix = essence_info.get("wineprefix", "").strip()
        language = essence_info.get('language', '').strip()

        # Build environment variables
        env_list = []
        if wineprefix:
            env_list.append(f'WINEPREFIX="{wineprefix}"')

        # Add locale variables if language is set
        if language:
            try:
                locale_code = language.split("(")[1].replace(")", "").strip() if "(" in language and ")" in language else language
                env_list.append(f"LC_ALL={locale_code}")
                env_list.append(f"LANG={locale_code}")
                env_list.append(f"LANGUAGE={locale_code}")
            except Exception:
                pass

        if env_vars:
            env_list.append(env_vars)

        # Build the command
        cmd_parts = []

        if env_list:
            cmd_parts.append("env")
            cmd_parts.extend(env_list)

        # Executor arguments
        executors_args = {
            "Azahar": {"executor_args": "-f"},
            "Cemu": {"executor_args": "-f -g"},
            "Dolphin": {"executor_args": "--batch -e"},
            "DuckStation": {"executor_args": "-fullscreen"},
            "Eden": {"executor_args": "-f -g"},
            "Flycast": {"executor_args": ""},
            "MelonDS": {"executor_args": "-f"},
            "mGBA": {"executor_args": "-f"},
            "PCSX2": {"executor_args": "-fullscreen"},
            "PPSSPP": {"executor_args": "--fullscreen --pause-menu-exit"},
            "RMG": {"executor_args": "--fullscreen"},
            "RPCS3": {"executor_args": "--no-gui --fullscreen"},
            "Ryubing": {"executor_args": "-f"},
            "Snes9x": {"executor_args": ""},
            "Wine": {"executor_args": ""},
            "UMU": {"executor_args": ""},
            "xemu": {"executor_args": "-full-screen -dvd_path"},
        }

        if executor == "Linux":
            cmd_parts.append(f'"{game_path}"')
        else:
            settings = load_settings()
            executor_cmd = settings["executor"].get(f"{executor.lower()}_command", "").strip()
            executor_package_type = settings["executor"].get(f"{executor.lower()}_package_type", "indefinite")

            # Only add quotes if package_type is indefinite
            if executor_package_type == "indefinite":
                cmd_parts.append(f'"{executor_cmd}"')
            else:
                cmd_parts.append(executor_cmd)

            executor_args = executors_args.get(executor, {"executor_args": ""}).get("executor_args", "").strip()
            if executor_args:
                cmd_parts.extend(executor_args.split())

            cmd_parts.append(f'"{game_path}"')

        if essence_args:
            cmd_parts.extend(essence_args.split())

        game_line = " ".join(cmd_parts)

        desktop_file = folder / f"meganimus-{safe_name}.desktop"
        gui_path = essence_data.get("gui_path", "")
        if not gui_path or not Path(gui_path).exists():
            gui_path = "applications-games"

        # Start building content lines
        content_lines = [
            "[Desktop Entry]",
            f"Name={name}",
            f"Exec={game_line}",
            f"Icon={gui_path}",
            f"Categories=Game;",
            "Keywords=gaming;essence;",
            "Type=Application",
            "StartupNotify=true",
            "Terminal=false",
            f"Comment={tr('SHORTCUT_COMMENT', name=name, executor=executor)}"
        ]

        # Add Path and StartupWMClass only for Wine or UMU
        if executor in ["Wine", "UMU"]:
            game_dir = str(Path(game_path).parent)
            content_lines.insert(3, f"Path={game_dir}")
            content_lines.insert(4, f"StartupWMClass={os.path.basename(game_path)}")

        try:
            with open(desktop_file, "w", encoding="utf-8") as f:
                f.write("\n".join(content_lines) + "\n")
        except Exception as e:
            print(tr("ERROR_CREATING_FILE", file=desktop_file, error=e))

