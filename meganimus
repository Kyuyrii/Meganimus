        parent_item.path = path
        parent_item.name_input = name_input
        parent_item.wineprefix_input = prefix_input

    def select_wineprefix_folder(self, line_edit: QLineEdit):
        dir_path = QFileDialog.getExistingDirectory(
            self,
            tr("SELECT_WINEPREFIX_FOLDER"),
            str(meganimus_home_dir))
        if dir_path:
            line_edit.setText(dir_path)

    def save_multiple(self):
        executor = self.executor_combo.currentText()
        if self.file_list.topLevelItemCount() == 0:
            QMessageBox.warning(self, tr("CREATE_ESSENCE"), tr("MANDATORY_FIELDS_ERROR"))
            return

        existing_names = set()
        for i in range(self.file_list.topLevelItemCount()):
            item = self.file_list.topLevelItem(i)
            name = item.name_input.text().strip()

            if not name:
                QMessageBox.warning(self, tr("APP_NAME"), tr("MANDATORY_FIELDS_ERROR"))
                return

            safe_essence_name = name.replace(" ", "_").lower()

            if safe_essence_name in existing_names:
                QMessageBox.warning(
                    self,
                    tr("APP_NAME"),
                    tr("DUPLICATE_NAME_IN_LIST", name=name))
                return
            existing_names.add(safe_essence_name)

            test_path = meganimus_config_dir / f"essence-info-{safe_essence_name}.toml"
            if test_path.exists():
                QMessageBox.warning(
                    self,
                    tr("APP_NAME"),
                    tr("ESSENCE_IN_MULTIPLE_CREATE_ALREADY_EXISTS", name=name))
                return

            try:
                with open(test_path, 'w', encoding="utf-8") as f:
                    tomlkit.dump({}, f)
                test_path.unlink()
            except Exception as e:
                QMessageBox.critical(
                    self,
                    tr("APP_NAME"),
                    tr("NAME_INVALID_IN_MULTIPLE", name=name, error=str(e)))
                return

        selected_lang = self.language_input.currentText()
        if selected_lang == tr("INDEFINITE"):
            selected_lang = ""

        for i in range(self.file_list.topLevelItemCount()):
            item = self.file_list.topLevelItem(i)
            name = item.name_input.text().strip()
            safe_essence_name = name.replace(" ", "_").lower()
            file_path = meganimus_config_dir / f"essence-info-{safe_essence_name}.toml"

            # Determine wineprefix
            if self.auto_wineprefix_cb.isChecked():
                prefix_path = Path(item.path)
                while prefix_path != prefix_path.parent:
                    if prefix_path.name.lower() == "drive_c":
                        prefix_path = prefix_path.parent
                        break
                    prefix_path = prefix_path.parent
                else:
                    prefix_path = Path(item.wineprefix_input.text()) if item.wineprefix_input.text() else ""
            else:
                prefix_path = Path(item.wineprefix_input.text()) if item.wineprefix_input.text() else ""

            # Save TOML
            try:
                with open(file_path, 'w', encoding="utf-8") as f:
                    tomlkit.dump({
                        "name": name,
                        "executor": executor,
                        "game_path": item.path,
                        "wineprefix": str(prefix_path) if prefix_path else "",
                        "gui_path": "",
                        "language": selected_lang,
                        "show_fps": False,
                        "env_vars": "",
                        "essence_args": ""
                    }, f)
            except Exception as e:
                QMessageBox.critical(self, tr("APP_NAME"), tr("FAILED_UPDATE_TOML", error=str(e)))
                return

        self.parent().load_essences()
        self.accept()

    def save_essence_data(self, data):
        safe_essence_name = data["name"].replace(" ", "_").lower()
        file_path = meganimus_config_dir / f"essence-info-{safe_essence_name}.toml"
        if file_path.exists():
            return
        with open(file_path, 'w', encoding="utf-8") as f:
            tomlkit.dump(data, f)

