    # In the MultipleEditEssenceDialog, mark all the innovations that are visible
    def mark_listed(self):
        if not getattr(self, "multiple_edit_dialog", None):
            return

        listed = []
        for rb in self.radio_buttons:
            if rb.isVisible():
                listed.append(rb.text())

        for name in listed:
            self.multiple_edit_dialog.set_checked_state(name, True)

    # In the Multiple Edit Essence Dialog, uncheck all the innovations that are visible
    def unmark_listed(self):
        if not getattr(self, "multiple_edit_dialog", None):
            return

        listed = []
        for rb in self.radio_buttons:
            if rb.isVisible():
                listed.append(rb.text())

