        save_settings(self.settings)
        self.parent().update_icon_size()

    def browse_executor(self, executor_name):
        widgets = self.executor_widgets[executor_name]
        if widgets["package_combo"].currentText() == tr("INDEFINITE"):
            path, _ = QFileDialog.getOpenFileName(self, tr("SELECT_FILE"))
            if path:
                widgets["path_input"].setText(path)

    def save_and_close(self):
        selected_style = self.style_combo.currentText()
        if selected_style == tr("INDEFINITE"):
            self.settings["design"]["qt_style"] = 'indefinite'
        else:
            self.settings["design"]["qt_style"] = selected_style
        selected_index = self.lang_combo.currentIndex()
        self.settings["design"]["language"] = list(available_languages.values())[selected_index]
        self.settings["design"]["layout_mode"] = ["classic", "grid", "list"][self.layout_mode_combo.currentIndex()]
        self.settings["other"]["sgdb_apikey"] = self.api_input.text().strip()

        # Save all executors
        for executor_name, widgets in self.executor_widgets.items():
            package_text = widgets["package_combo"].currentText()
            if package_text == tr("INDEFINITE"):
                package_type = "indefinite"
            else:
                package_type = package_text

            self.settings["executor"][f"{executor_name.lower()}_package_type"] = package_type
            self.settings["executor"][f"{executor_name.lower()}_command"] = widgets["path_input"].text()

        save_settings(self.settings)
        self.accept()

