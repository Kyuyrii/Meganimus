            self.essence_gui_input.setText(file_path)

    def get_form_data(self):
        env_vars_text = self.env_vars_input.text().strip()
        selected_lang = self.language_input.currentText()
        if selected_lang == tr("INDEFINITE"):
            selected_lang = ""

        gui_path = self.essence_gui_input.text().strip()

        return {
            "name": self.name_input.text(),
            "executor": self.executor_combo.currentText(),
            "game_path": self.game_path_input.text(),
            "gui_path": gui_path,
            "wineprefix": self.wineprefix_input.text().strip(),
            "language": selected_lang,
            "env_vars": env_vars_text,
            "essence_args": self.essence_args_input.text(),
        }

    def save_and_accept(self):
        essence_data = self.get_form_data()
        if essence_data["name"] and essence_data["game_path"]:

            safe_essence_name = essence_data["name"].replace(" ", "_").lower()
            essence_file = meganimus_config_dir / f"essence-info-{safe_essence_name}.toml"

            # Check for duplicate essence name
            if essence_file.exists() and (not self.essence_data or self.essence_data.get("name", "").lower() != essence_data["name"].lower()):
                QMessageBox.warning(self, tr("APP_NAME"), tr("ESSENCE_ALREADY_EXISTS"))
                return

            # gui_path
            if essence_data.get("gui_path"):
                gui_path = Path(essence_data["gui_path"])
                if gui_path.exists() and gui_path.is_file():
                    if self.essence_data and self.essence_data.get("gui_path"):
                        old_gui_path = Path(self.essence_data['gui_path'])
                        if old_gui_path != gui_path:
                            old_safe_name = self.essence_data.get('name', '').replace(" ", "_").lower()
                            for old_file in meganimus_gui_dir.glob(f"{old_safe_name}.*"):
                                try:
                                    old_file.unlink()
                                except Exception:
                                    pass

                    if gui_path.parent != meganimus_gui_dir:
                        gui_extension = gui_path.suffix.lower()
                        new_gui_path = meganimus_gui_dir / f"{safe_essence_name}{gui_extension}"
                        try:
                            shutil.copyfile(gui_path, new_gui_path)
                            essence_data["gui_path"] = str(new_gui_path)
                        except Exception:
                            essence_data["gui_path"] = ""
                    else:
                        if self.essence_data:
                            old_safe_name = self.essence_data.get('name', '').replace(" ", "_").lower()
                            if old_safe_name != safe_essence_name:
                                new_gui_path = meganimus_gui_dir / f"{safe_essence_name}{gui_path.suffix.lower()}"
                                try:
                                    gui_path.rename(new_gui_path)
                                    essence_data["gui_path"] = str(new_gui_path)
                                except Exception:
                                    essence_data["gui_path"] = str(gui_path)
            elif self.essence_data and self.essence_data.get("gui_path"):
                old_gui_path = Path(self.essence_data['gui_path'])
                if old_gui_path.exists() and old_gui_path.is_file() and old_gui_path.parent == meganimus_gui_dir:
                    try:
                        old_gui_path.unlink()
                    except Exception:
                        pass
                essence_data["gui_path"] = ""

            # Save TOML
            try:
                with open(essence_file, 'w', encoding="utf-8") as f:
                    tomlkit.dump(essence_data, f)
            except Exception as e:
                QMessageBox.critical(self, tr("APP_NAME"), tr("NAME_INVALID", error=str(e)))
                return

            # Remove old TOML if name changed
            if self.essence_data:
                old_safe_essence_name = self.essence_data.get('name', '').replace(" ", "_").lower()
                new_safe_essence_name = essence_data['name'].replace(" ", "_").lower()
                if old_safe_essence_name != new_safe_essence_name:
                    old_essence_file_path = meganimus_config_dir / f"essence-info-{old_safe_essence_name}.toml"
                    if old_essence_file_path.exists():
                        old_essence_file_path.unlink()

            self.parent().load_essences()
            self.accept()
        else:
            QMessageBox.warning(self, tr("CREATE_ESSENCE"), tr("MANDATORY_FIELDS_ERROR"))

    def delete_essence(self):
        essence_name = self.name_input.text().strip()
        msg = QMessageBox(self)
        msg.setIcon(QMessageBox.Icon.Warning)
        msg.setWindowTitle(tr("REMOVE"))
        msg.setText(tr("DELETE_ESSENCE_CONFIRM_MESSAGE", name=essence_name))
        msg.setStandardButtons(QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)

        if msg.exec() != QMessageBox.StandardButton.Yes:
            return

        safe_essence_name = essence_name.replace(" ", "_").lower()
        essence_file = meganimus_config_dir / f"essence-info-{safe_essence_name}.toml"

        with open(essence_file, encoding='utf-8') as f:
            essence_data = tomlkit.load(f)

        essence_file.unlink()

        gui = essence_data.get('gui_path')
        if gui:
            gui_path = Path(gui)
            if gui_path.exists() and gui_path.is_file():
                try:
                    gui_path.unlink()
                except Exception:
                    pass

        self.parent().load_essences()
        self.accept()

